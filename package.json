{
  "name": "jimos-home-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "tsc -b && vite --config vite.config.ts build",
    "preview": "vite --config vite.config.ts preview --host 0.0.0.0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "android:add": "cap add android",
    "android:sync": "cap sync android",
    "android:build": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "8.4.2",
    "@capacitor/core": "8.4.2",
    "@fontsource/noto-sans-tc": "^5.2.8",
    "lucide-react": "^0.468.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "6.0.3",
    "fake-indexeddb": "^6.0.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "8.1.5",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  }
}
